{
  "name": "@abhyas/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "env:init": "tsx scripts/init-env.ts",
    "dev": "tsx watch src/index.ts",
    "predev": "tsx scripts/init-env.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "load:test": "tsx scripts/load-test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@supabase/supabase-js": "^2.106.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.6.2",
    "pino": "^10.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/node": "^22.16.5",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.6",
    "globals": "^15.15.0",
    "prettier": "^3.7.3",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.15"
  }
}
